#APP
APP_NAME='Nadi'
APP_PORT=8090
APP_ENV=development
APP_URL=http://localhost:8090

# DATABASE LOCAL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nadi_db
DB_USERNAME=root 
DB_PASSWORD=
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_MAX_LIFETIME=60

# # DATABASE PROD
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=nadi_db
# DB_USERNAME=nadi
# DB_PASSWORD=vutrD&%f7g975FGVghvgh*@14kd
# DB_MAX_IDLE_CONNS=10
# DB_MAX_OPEN_CONNS=100
# DB_MAX_LIFETIME=60


# REDIS
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-Token
CORS_EXPOSED_HEADERS=
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# JWT
JWT_SECRET=your-secret-key
JWT_ISSUER=Nadi
JWT_ACCESS_EXPIRATION_TIME=15m
JWT_REFRESH_EXPIRATION_TIME=168h

# RATE LIMIT
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# SECURITY
REQUEST_TIMEOUT=30
API_KEY=your-secret-key
BCRYPT_COST=8 # 12 for Production
ENCRYPTION_KEY=your-secret-key

# LOGGING DIR
LOG_DIR=./storage/logs
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# MAIL
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your-secret-key
MAIL_PASSWORD=your-secret-key
MAIL_FROM_ADDRESS=no-reply@nadi.id

# KAFKA
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=password-reset


# FRONTEND 
FRONTEND_URL=http://localhost:5173

# GOOGLE AUTH
GOOGLE_CLIENT_ID=your-secret-key


# 1. Change all default passwords and secrets
# 2. Use strong, unique values for JWT_SECRET and ENCRYPTION_KEY
# 3. Set APP_ENV=production for production deployments
# 4. Use HTTPS in production (APP_URL should be https://)
# 5. Configure proper CORS origins for production
# 6. Use environment-specific database credentials
# 7. Enable proper logging and monitoring
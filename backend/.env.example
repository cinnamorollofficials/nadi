# Application Configuration
APP_NAME=Nadi
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=nadi_db
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100
DB_MAX_LIFETIME=60

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=300

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-Token
CORS_MAX_AGE=86400
CORS_EXPOSED_HEADERS=
CORS_ALLOW_CREDENTIALS=true

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_ISSUER=nadi-app
JWT_ACCESS_EXPIRATION_TIME=15m
JWT_REFRESH_EXPIRATION_TIME=168h

# Rate Limiting
RATE_LIMIT_RPS=100
RATE_LIMIT_BURST=200

# Security Configuration
REQUEST_TIMEOUT=30
API_KEY=your-api-key-here
BCRYPT_COST=12
ADMIN_EMAIL=admin@nadi.com
ADMIN_PASSWORD=admin123
# CRITICAL: Generate a 32-byte (256-bit) encryption key for sensitive data
# You can generate one using: openssl rand -base64 32
ENCRYPTION_KEY=your-base64-encoded-32-byte-encryption-key-here

# Logging Configuration
LOG_DIR=./storage/logs
LOG_LEVEL=info
LOG_RETENTION_DAYS=30

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_ADDRESS=noreply@nadi.com

# Kafka Configuration (Optional)
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=nadi-events

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Storage Configuration
STORAGE_BASE_PATH=./storage/uploads
STORAGE_MAX_FILE_SIZE_MB=50

# Google OAuth Configuration
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Production Security Notes:
# 1. Change all default passwords and secrets
# 2. Use strong, unique values for JWT_SECRET and ENCRYPTION_KEY
# 3. Set APP_ENV=production for production deployments
# 4. Use HTTPS in production (APP_URL should be https://)
# 5. Configure proper CORS origins for production
# 6. Use environment-specific database credentials
# 7. Enable proper logging and monitoring
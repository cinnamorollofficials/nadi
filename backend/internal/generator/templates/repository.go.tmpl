func (r *{{.ModuleNameLower}}Repository) FindAll(ctx context.Context, pagination *defaultDto.PaginationRequest) ([]entity.{{.ModuleName}}, int64, error) {
	var entities []entity.{{.ModuleName}}
	var total int64

	query := r.db.WithContext(ctx).Model(&entity.{{.ModuleName}}{})

	{{if .HasSearchableFields}}
	if pagination.Search != "" {
		{{- range $i, $f := .Fields}}
		{{- if .Searchable}}
		{{- if eq $i 0}}
		query = query.Where("{{.NameSql}} LIKE ?", "%"+pagination.Search+"%")
		{{- else}}
		query = query.Or("{{.NameSql}} LIKE ?", "%"+pagination.Search+"%")
		{{- end}}
		{{- end}}
		{{- end}}
	}
	{{end}}

	if err := query.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	offset := (pagination.GetPage() - 1) * pagination.GetLimit()
	err := query.Order("id DESC").
		Limit(pagination.GetLimit()).
		Offset(offset).
		Find(&entities).Error

	return entities, total, err
}


func (s *{{.ModuleNameLower}}Service) Create(ctx context.Context, req dto.Create{{.ModuleName}}Request) (*dto.{{.ModuleName}}Response, error) {
	entity := &entity.{{.ModuleName}}{
		{{- range .Fields}}
		{{.NameGo}}: req.{{.NameGo}},
		{{- end}}
	}

	if err := s.repo.Create(ctx, entity); err != nil {
		return nil, err
	}

	s.cache.DeletePattern(ctx, "{{.TableName}}:*")

	{{if .AuditLog}}
	logger.AuditLogger.Info().
		Uint("{{.ModuleNameLower}}_id", entity.ID).
		Str("action", "{{.ModuleNameLower}}_creation").
